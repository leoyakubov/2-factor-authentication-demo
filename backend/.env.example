SERVER_PORT=8081
MONGODB_HOST=localhost
MONGODB_DATABASE=spring-boot-jwt-auth
MONGODB_PORT=27018
JWT_HEADER=Authorization
JWT_PREFIX=Bearer
JWT_EXPIRATION=86400
JWT_SECRET=replace-with-a-long-random-secret
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=PT10M
AUTH_RATE_LIMIT_LOCKOUT=PT15M
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_ORIGIN=http://localhost:8081
# Optional: override the default CSP if you need to tighten or relax browser restrictions.
CONTENT_SECURITY_POLICY=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:3000 http://localhost:8081
