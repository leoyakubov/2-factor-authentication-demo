SERVER_PORT=8081
MONGODB_HOST=localhost
MONGODB_DATABASE=two-factor-authentication-demo
MONGODB_PORT=27018
JWT_HEADER=Authorization
JWT_PREFIX=Bearer
JWT_EXPIRATION=PT24H
JWT_SECRET=replace-with-a-long-random-secret
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW=PT10M
AUTH_RATE_LIMIT_LOCKOUT=PT15M
FRONTEND_ORIGIN=http://localhost:3000
BACKEND_ORIGIN=http://localhost:8081
# Optional: override the generated CSP if you need deployment-specific restrictions.
CONTENT_SECURITY_POLICY=
