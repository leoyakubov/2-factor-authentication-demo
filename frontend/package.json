{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "6.2.5",
    "antd": "6.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.16.0"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --port 3000 --strictPort",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "test": "node ./node_modules/jest/bin/jest.js --watch",
    "test:ci": "node ./scripts/test-ci.cjs",
    "verify": "npm run lint && npm run test:ci && npm run build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --port 3000 --strictPort"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.7",
