    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "6.0.2",
    "babel-jest": "30.4.1",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "vite": "8.0.16"
  }
